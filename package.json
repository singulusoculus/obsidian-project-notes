{
  "name": "obsidian-project-notes",
  "version": "0.0.1",
  "description": "Area-based project notes and task views for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "svelte",
    "project-management"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.17.24",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "esbuild-svelte": "^0.9.3",
    "obsidian": "latest",
    "svelte": "^5.25.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2"
  }
}
